{
  "buildCommand": "cd web-admin/frontend && npm install && npm run build",
  "outputDirectory": "web-admin/frontend/dist",
  "framework": null,
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
